{
    "name": "@solivan/malachite",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "private": false,
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build:js": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
        "build:types": "tsc --project tsconfig.build.json",
        "build:all": "bun run clean && bun run build:js && bun run build:types",
        "format": "prettier --write .",
        "lint": "eslint src/**/*.ts"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.9"
    },
    "peerDependencies": {
        "typescript": "^6.0.0"
    }
}
